# Strava API credentials
# Register at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# OAuth redirect URI (for initial authorization only)
# Default works for local first-time auth
STRAVA_REDIRECT_URI=http://localhost:8765/callback

# Paths (optional overrides)
PACED_CONFIG_DIR=~/.paced
PACED_DB_PATH=~/.paced/paced.db

# Log level
PACED_LOG_LEVEL=INFO
